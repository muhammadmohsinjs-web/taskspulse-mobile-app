# TasksPulse Backend — Environment Variables
# Copy this file to .env and fill in your values.
# .env is git-ignored — secrets stay local.

# ─── Environment ───────────────────────────────────────────
ENVIRONMENT=development

# ─── Database ───────────────────────────────────────────────
# Default: SQLite stored next to database.py
# DATABASE_URL=sqlite:///./taskspulse.db

# ─── JWT ────────────────────────────────────────────────────
# Generate a strong secret for production:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=dev-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# ─── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=*

# ─── Email (SMTP) ───────────────────────────────────────────
# Set to true to send real emails. When false (default),
# verification emails are logged but not sent.
EMAIL_ENABLED=true

# Sender identity
EMAIL_FROM_ADDRESS=your-email@example.com
EMAIL_FROM_NAME=TasksPulse

# SMTP server (use Resend, Postmark, SendGrid, Mailgun, etc.)
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=your-smtp-username
SMTP_PASSWORD=your-smtp-password

# TLS settings
# Port 587 → STARTTLS (SMTP_START_TLS=true,  SMTP_USE_TLS=false)
# Port 465 → TLS      (SMTP_START_TLS=false, SMTP_USE_TLS=true)
SMTP_START_TLS=true
SMTP_USE_TLS=false

# Socket timeout in seconds
SMTP_TIMEOUT_SECONDS=10

# Public URL users click in the email
# For production: https://your-api-domain.com/auth/verify-email
EMAIL_VERIFICATION_URL_BASE=http://localhost:8000/auth/verify-email

# Hours before the verification token expires
EMAIL_VERIFICATION_EXPIRE_HOURS=24

# When true, prints the raw token to server logs (dev only)
EMAIL_DEBUG_PRINT_TOKENS=false
